<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.SupplyChainAgroSystem" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/color_primary_green</item>
        <item name="colorSecondary">@color/color_accent_terracotta</item>
        <item name="android:windowBackground">@color/color_bg_warm</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/color_bg_warm</item>
    </style>

    <!-- Style for custom numeric keyboard keys -->
    <style name="Widget.App.KeyboardKey" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textColor">@color/color_text_dark</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/color_border_grey</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>