<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_warm"
    android:padding="24dp">

    <!-- Back Button -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/color_border_grey"
        app:cardBackgroundColor="@color/color_surface_warm"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_back_arrow" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Header Content -->
    <TextView
        android:id="@+id/text_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Masukkan kode dari SMS"
        android:textColor="@color/color_text_dark"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/text_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/color_text_muted"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/text_header"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 6-digit OTP Box Row -->
    <LinearLayout
        android:id="@+id/layout_otp_boxes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@id/text_sub">

        <TextView android:id="@+id/box_1" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textColor="@color/color_text_dark" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/bg_otp_box" />
        <TextView android:id="@+id/box_2" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textColor="@color/color_text_dark" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/bg_otp_box" />
        <TextView android:id="@+id/box_3" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textColor="@color/color_text_dark" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/bg_otp_box" />
        <TextView android:id="@+id/box_4" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textColor="@color/color_text_dark" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/bg_otp_box" />
        <TextView android:id="@+id/box_5" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textColor="@color/color_text_dark" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/bg_otp_box" />
        <TextView android:id="@+id/box_6" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:gravity="center" android:textColor="@color/color_text_dark" android:textSize="20sp" android:textStyle="bold" android:background="@drawable/bg_otp_box" />

    </LinearLayout>

    <!-- Error Label -->
    <TextView
        android:id="@+id/text_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Kode OTP yang dimasukkan salah"
        android:textColor="@color/color_red_error"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layout_otp_boxes"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Resend OTP Code link -->
    <TextView
        android:id="@+id/text_resend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Kirim kode kembali"
        android:textColor="@color/color_text_muted"
        android:alpha="0.7"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/text_error"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Help layout -->
    <LinearLayout
        android:id="@+id/layout_help"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/keyboard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Butuh bantuan masuk?"
            android:textColor="@color/color_text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kami siap membantu! "
                android:textColor="@color/color_text_muted"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/text_help_support"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hubungi Dukungan"
                android:textColor="@color/color_accent_terracotta"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Custom Virtual Keyboard -->
    <TableLayout
        android:id="@+id/keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*"
        app:layout_constraintBottom_toBottomOf="parent">

        <TableRow android:layout_marginBottom="4dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/key_1" style="@style/Widget.App.KeyboardKey" android:text="1" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_2" style="@style/Widget.App.KeyboardKey" android:text="2" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_3" style="@style/Widget.App.KeyboardKey" android:text="3" />
        </TableRow>
        <TableRow android:layout_marginBottom="4dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/key_4" style="@style/Widget.App.KeyboardKey" android:text="4" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_5" style="@style/Widget.App.KeyboardKey" android:text="5" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_6" style="@style/Widget.App.KeyboardKey" android:text="6" />
        </TableRow>
        <TableRow android:layout_marginBottom="4dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/key_7" style="@style/Widget.App.KeyboardKey" android:text="7" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_8" style="@style/Widget.App.KeyboardKey" android:text="8" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_9" style="@style/Widget.App.KeyboardKey" android:text="9" />
        </TableRow>
        <TableRow>
            <View android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="4dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_0" style="@style/Widget.App.KeyboardKey" android:text="0" />
            <com.google.android.material.button.MaterialButton android:id="@+id/key_del" style="@style/Widget.App.KeyboardKey" android:text="⌫" />
        </TableRow>
    </TableLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
