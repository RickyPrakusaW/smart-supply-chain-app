<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <!-- USER MESSAGE CONTAINER (Right-Aligned) -->
    <LinearLayout
        android:id="@+id/layout_user_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:gravity="end"
        android:orientation="vertical"
        android:layout_marginStart="64dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/color_primary_green">

            <TextView
                android:id="@+id/text_user_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="Pertanyaan pengguna disini..."
                android:textColor="@color/white"
                android:textSize="13.5sp"
                android:lineSpacingExtra="2dp" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text_user_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="02:00"
            android:textColor="@color/color_text_muted"
            android:textSize="9.5sp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="4dp" />

    </LinearLayout>

    <!-- AI MESSAGE CONTAINER (Left-Aligned) -->
    <LinearLayout
        android:id="@+id/layout_ai_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:gravity="start"
        android:orientation="vertical"
        android:layout_marginEnd="64dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/color_border_grey"
            app:cardBackgroundColor="@color/color_surface_warm">

            <TextView
                android:id="@+id/text_ai_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="Jawaban asisten tani pintar disini..."
                android:textColor="@color/color_text_dark"
                android:textSize="13.5sp"
                android:lineSpacingExtra="2dp" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text_ai_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="02:00"
            android:textColor="@color/color_text_muted"
            android:textSize="9.5sp"
            android:layout_marginTop="2dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</LinearLayout>
