<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_farmer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/color_surface_warm"
    app:strokeColor="@color/color_border_grey"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Farmer Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/image_container"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/image_illustration"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/sapi" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Farmer Name -->
        <TextView
            android:id="@+id/text_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Koperasi Susu Pujon"
            android:textColor="@color/color_text_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/image_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/layout_rating" />

        <!-- Rating Container -->
        <LinearLayout
            android:id="@+id/layout_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="@color/color_accent_terracotta" />

            <TextView
                android:id="@+id/text_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="5.0"
                android:textColor="@color/color_text_dark"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Location -->
        <TextView
            android:id="@+id/text_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:text="Pujon, Malang"
            android:textColor="@color/color_text_muted"
            android:textSize="11sp"
            app:layout_constraintStart_toEndOf="@id/image_container"
            app:layout_constraintTop_toBottomOf="@id/text_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Distance -->
        <TextView
            android:id="@+id/text_distance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="12 km dari lokasi Anda"
            android:textColor="@color/color_accent_terracotta"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/image_container"
            app:layout_constraintTop_toBottomOf="@id/text_location"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tags row (horizontal list of chips/badges) -->
        <LinearLayout
            android:id="@+id/layout_tags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toEndOf="@id/image_container"
            app:layout_constraintTop_toBottomOf="@id/text_distance"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Dynamic textview tags can be added programmatically or simple placeholders -->
            <TextView
                android:id="@+id/tag1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_olive"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Keju"
                android:textColor="@color/color_text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tag2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_olive"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Susu"
                android:textColor="@color/color_text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tag3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_olive"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Mentega"
                android:textColor="@color/color_text_muted"
                android:textSize="9sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
