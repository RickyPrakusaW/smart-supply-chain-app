<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_warm">

    <!-- Header Panel -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/color_surface_warm"
        android:elevation="4dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/color_border_grey"
            app:cardBackgroundColor="@color/color_surface_warm">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/color_primary_green" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/text_chatting_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Lawan Bicara"
                android:textColor="@color/color_text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mitra AgriMitra"
                android:textColor="@color/color_text_muted"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Message Recycler View -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_direct_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layout_input_bar"
        android:layout_below="@+id/layout_header"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Bottom Input Bar -->
    <LinearLayout
        android:id="@+id/layout_input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="@color/color_surface_warm"
        android:elevation="8dp">

        <EditText
            android:id="@+id/input_chat_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Tulis pesan..."
            android:textColor="@color/color_text_dark"
            android:textSize="14sp"
            android:background="@drawable/bg_search_white"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:minHeight="44dp"
            android:maxLines="4" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_send_chat"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/color_primary_green">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</RelativeLayout>
