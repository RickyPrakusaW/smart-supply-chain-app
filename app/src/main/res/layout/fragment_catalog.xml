<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg_warm">

    <!-- Segmented Tab Row -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_catalog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_bg_warm"
        app:tabTextColor="@color/color_text_muted"
        app:tabSelectedTextColor="@color/color_primary_green"
        app:tabIndicatorColor="@color/color_primary_green"
        app:tabIndicatorHeight="3dp"
        app:tabTextAppearance="@android:style/TextAppearance.Widget.TabWidget"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Produk" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Petani" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resep" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Sub Content Container -->
    <FrameLayout
        android:id="@+id/container_catalog"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Sub Content 1: Products (Reuse SearchResultsLayout category row + grid) -->
        <LinearLayout
            android:id="@+id/layout_catalog_products"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_products_grid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="18dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Sub Content 2: Farmers -->
        <LinearLayout
            android:id="@+id/layout_catalog_farmers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_farmers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="12dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Sub Content 3: Recipes -->
        <LinearLayout
            android:id="@+id/layout_catalog_recipes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_recipes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="18dp"
                android:paddingTop="12dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
