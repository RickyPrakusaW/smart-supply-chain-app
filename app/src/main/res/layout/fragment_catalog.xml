<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg_warm">

    <!-- Segmented Tab Row -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_catalog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_bg_warm"
        app:tabTextColor="@color/color_text_muted"
        app:tabSelectedTextColor="@color/color_primary_green"
        app:tabIndicatorColor="@color/color_primary_green"
        app:tabIndicatorHeight="3dp"
        app:tabTextAppearance="@android:style/TextAppearance.Widget.TabWidget"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Produk" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Petani" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resep" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edamam" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Sub Content Container -->
    <FrameLayout
        android:id="@+id/container_catalog"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Sub Content 1: Products (Reuse SearchResultsLayout category row + grid) -->
        <LinearLayout
            android:id="@+id/layout_catalog_products"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_products_grid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="18dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Sub Content 2: Farmers -->
        <LinearLayout
            android:id="@+id/layout_catalog_farmers"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_farmers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="12dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Sub Content 3: Recipes -->
        <LinearLayout
            android:id="@+id/layout_catalog_recipes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_recipes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="18dp"
                android:paddingTop="12dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Sub Content 4: Edamam Food Database Catalog -->
        <LinearLayout
            android:id="@+id/layout_catalog_edamam"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Search input layout for Edamam -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_search_edamam"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:startIconDrawable="@android:drawable/ic_menu_search"
                    app:boxStrokeColor="@color/color_primary_green"
                    app:hintTextColor="@color/color_primary_green">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_search_edamam"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Cari nutrisi makanan..."
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_search_edamam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Cari"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/color_primary_green"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Loading indicator for Edamam -->
            <ProgressBar
                android:id="@+id/progress_edamam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_margin="24dp" />

            <!-- Empty state for Edamam -->
            <TextView
                android:id="@+id/text_empty_edamam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ketik makanan lalu klik cari untuk melihat info nutrisi Edamam."
                android:textColor="@color/color_text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_margin="24dp" />

            <!-- RecyclerView for Edamam Food Catalog -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_catalog_edamam"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp"
                android:paddingBottom="80dp"
                android:clipToPadding="false" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
