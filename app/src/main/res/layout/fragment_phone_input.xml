<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.agroSystem.app.features.auth.AuthViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_bg_warm">

        <!-- Scrollable Form Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/keyboard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <!-- Back Button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/color_border_grey"
                    app:cardBackgroundColor="@color/color_surface_warm"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_back_arrow" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Header Content -->
                <TextView
                    android:id="@+id/text_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Masuk dengan nomor telepon"
                    android:textColor="@color/color_text_dark"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/btn_back"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/text_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Untuk mendapatkan akses ke semua fitur aplikasi"
                    android:textColor="@color/color_text_muted"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/text_header"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Phone Display Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_phone"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/color_border_grey"
                    app:cardBackgroundColor="@color/color_surface_warm"
                    app:layout_constraintTop_toBottomOf="@id/text_sub"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+62 "
                            android:textColor="@color/color_text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_phone_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/color_text_dark"
                            android:textSize="16sp"
                            android:textStyle="normal" />

                        <TextView
                            android:id="@+id/text_phone_placeholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="812-3456-7890"
                            android:textColor="@color/color_text_muted"
                            android:textColorHint="@color/color_text_muted"
                            android:alpha="0.4"
                            android:textSize="16sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Lanjutkan Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_continue"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:text="Lanjutkan"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:enabled="false"
                    app:backgroundTint="@color/color_primary_green"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/card_phone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Privacy Legal Text -->
                <TextView
                    android:id="@+id/text_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Dengan menekan tombol, Anda menyetujui kebijakan pemrosesan data pribadi kami."
                    android:textColor="@color/color_text_muted"
                    android:alpha="0.7"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.2"
                    app:layout_constraintTop_toBottomOf="@id/btn_continue"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Divider OR -->
                <LinearLayout
                    android:id="@+id/divider_or"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/text_privacy"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/color_border_grey" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ATAU "
                        android:textColor="@color/color_text_muted"
                        android:textSize="12sp"
                        android:layout_marginHorizontal="12dp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/color_border_grey" />
                </LinearLayout>

                <!-- Google Sign-In Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_google"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:text="Masuk dengan Google"
                    android:textColor="@color/color_text_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:strokeColor="@color/color_border_grey"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/white"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:iconTint="@null"
                    app:layout_constraintTop_toBottomOf="@id/divider_or"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Help support text -->
                <LinearLayout
                    android:id="@+id/layout_help"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/btn_google"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Butuh bantuan masuk?"
                        android:textColor="@color/color_text_muted"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kami siap membantu! "
                            android:textColor="@color/color_text_muted"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/text_help_support"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hubungi Dukungan"
                            android:textColor="@color/color_accent_terracotta"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Guest Mode Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_guest"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    android:text="Saya hanya ingin melihat-lihat"
                    android:textColor="@color/color_text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:strokeColor="@color/color_border_grey"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/color_surface_warm"
                    app:layout_constraintTop_toBottomOf="@id/layout_help"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Custom Virtual Keyboard (Fixed at bottom) -->
        <TableLayout
            android:id="@+id/keyboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TableRow android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/key_1" style="@style/Widget.App.KeyboardKey" android:text="1" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_2" style="@style/Widget.App.KeyboardKey" android:text="2" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_3" style="@style/Widget.App.KeyboardKey" android:text="3" />
            </TableRow>
            <TableRow android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/key_4" style="@style/Widget.App.KeyboardKey" android:text="4" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_5" style="@style/Widget.App.KeyboardKey" android:text="5" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_6" style="@style/Widget.App.KeyboardKey" android:text="6" />
            </TableRow>
            <TableRow android:layout_marginBottom="4dp">
                <com.google.android.material.button.MaterialButton android:id="@+id/key_7" style="@style/Widget.App.KeyboardKey" android:text="7" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_8" style="@style/Widget.App.KeyboardKey" android:text="8" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_9" style="@style/Widget.App.KeyboardKey" android:text="9" />
            </TableRow>
            <TableRow>
                <View android:layout_width="0dp" android:layout_height="48dp" android:layout_margin="4dp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_0" style="@style/Widget.App.KeyboardKey" android:text="0" />
                <com.google.android.material.button.MaterialButton android:id="@+id/key_del" style="@style/Widget.App.KeyboardKey" android:text="⌫" />
            </TableRow>
        </TableLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
