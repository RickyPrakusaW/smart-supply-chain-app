<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg_warm"
    android:paddingBottom="24dp">

    <!-- Header bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/color_text_dark"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Filter"
                android:textColor="@color/color_text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bersihkan"
            android:textColor="@color/color_text_muted"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true" />

    </RelativeLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Active parameters container (chips) -->
            <LinearLayout
                android:id="@+id/layout_active_parameters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Parameter Terpilih"
                    android:textColor="@color/color_text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layout_active_chips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <!-- Populated programmatically -->
                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

            <!-- Delivery Days -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waktu Pengiriman"
                android:textColor="@color/color_text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/chip_delivery_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Hari Ini"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_delivery_tomorrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Besok"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_delivery_3days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="s.d 3 Hari"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_delivery_5days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="s.d 5 Hari"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Production region -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wilayah Produksi"
                android:textColor="@color/color_text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/chip_region_malang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Malang Raya"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_region_closest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Terdekat"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Eco-friendly Switch row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kemasan Ramah Lingkungan"
                        android:textColor="@color/color_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gunakan paperbag / bio-degradable bag"
                        android:textColor="@color/color_text_muted"
                        android:textSize="11sp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_eco_friendly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />

            </RelativeLayout>

            <!-- Discount Switch row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hanya Produk Diskon"
                        android:textColor="@color/color_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tampilkan komoditas berlabel coret saja"
                        android:textColor="@color/color_text_muted"
                        android:textSize="11sp" />

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_discount_only"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />

            </RelativeLayout>

            <!-- Diets, Allergens, Nutrients headings & lists -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nutrisi &amp; Kesehatan"
                android:textColor="@color/color_text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- Program Diet -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Program Diet"
                android:textColor="@color/color_text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/chip_diet_veg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Vegetarian"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_diet_vegan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Vegan"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_diet_keto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Keto"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Allergens -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kandungan / Bebas Alergen"
                android:textColor="@color/color_text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/chip_allergen_lactose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Bebas Laktosa"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_allergen_gluten"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Bebas Gluten"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Nutrients -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mikroelemen &amp; Nutrisi"
                android:textColor="@color/color_text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/chip_nutr_calcium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Tinggi Kalsium"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_nutr_protein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Tinggi Protein"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_nutr_fiber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_olive"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Kaya Serat"
                    android:textColor="@color/color_text_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply_filters"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginHorizontal="24dp"
        android:text="Tampilkan 8 Produk"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/color_primary_green"
        app:cornerRadius="14dp" />

</LinearLayout>
