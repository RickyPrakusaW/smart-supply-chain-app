<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_warm">

    <!-- Top Action Bar (Back button and Title) -->
    <LinearLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/color_border_grey"
            app:cardBackgroundColor="@color/color_surface_warm">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back_arrow" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Pilih Alamat Pengiriman"
            android:textColor="@color/color_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Map Container (Anchored at the top below header) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_map"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/color_border_grey"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <org.osmdroid.views.MapView
                android:id="@+id/map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Static Center target marker -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_marginBottom="18dp"
                android:src="@drawable/ic_location_radar"
                app:tint="@color/color_primary_green" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable Form Container (Bottom Half) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/card_map"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Search Address Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_search_address"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cari nama lokasi / jalan..."
                app:boxStrokeColor="@color/color_primary_green"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxBackgroundColor="@color/color_surface_warm"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/color_text_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_search_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dark"
                    android:inputType="textPostalAddress"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_border_grey"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Field 1: Nama Jalan Utama (Auto-filled by map/search) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_selected_street"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nama Jalan Utama (Auto-fill / Tulis)"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/color_primary_green"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxBackgroundColor="@color/color_surface_warm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/text_selected_street"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dark"
                    android:inputType="textPostalAddress"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Field 2: Detail No. Rumah / Unit -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_selected_detail"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="No. Rumah, RT/RW, Blok, Unit"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/color_primary_green"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxBackgroundColor="@color/color_surface_warm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/text_selected_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dark"
                    android:inputType="textPostalAddress"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Field 3: Kode Pos (5 Digit) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_selected_postal_code"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Kode Pos (5 Digit)"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/color_primary_green"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxBackgroundColor="@color/color_surface_warm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/text_selected_postal_code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dark"
                    android:inputType="number"
                    android:maxLength="5"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Field 4: Patokan / Landmark -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_selected_landmark"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Patokan / Petunjuk Alamat"
                android:layout_marginBottom="24dp"
                app:boxStrokeColor="@color/color_primary_green"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxBackgroundColor="@color/color_surface_warm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/text_selected_landmark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dark"
                    android:inputType="textPostalAddress"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Save Address Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_continue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Simpan Alamat Pengiriman"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/color_primary_green"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
