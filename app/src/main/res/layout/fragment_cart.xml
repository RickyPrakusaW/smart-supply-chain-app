<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_warm">

    <!-- Active Cart Content Layout -->
    <LinearLayout
        android:id="@+id/layout_active_cart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/color_text_dark"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Keranjang"
                    android:textColor="@color/color_text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_share"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="@color/color_text_dark"
                    android:clickable="true"
                    android:focusable="true" />

                <Space
                    android:layout_width="16dp"
                    android:layout_height="match_parent" />

                <ImageView
                    android:id="@+id/btn_clear"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="@color/color_text_dark"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Location Delivery Bar -->
        <LinearLayout
            android:id="@+id/btn_location_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/color_surface_warm"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="@color/color_accent_terracotta" />

            <TextView
                android:id="@+id/text_delivery_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Kirim ke: Jalan Sawah Indah No. 12"
                android:textColor="@color/color_text_dark"
                android:textSize="12sp"
                android:textStyle="normal" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="@color/color_text_muted" />

        </LinearLayout>

        <!-- Scrollable items listing -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="10dp" />

                <!-- Grouped Items RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cart_groups"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <!-- Packaging Section Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/color_border_grey"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface_warm">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Kemasan Pesanan"
                            android:textColor="@color/color_text_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- Option 0: Paperbag -->
                        <RelativeLayout
                            android:id="@+id/btn_option_paperbag"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingVertical="4dp">

                            <RadioButton
                                android:id="@+id/radio_paperbag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:clickable="false" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/radio_paperbag"
                                android:layout_marginStart="6dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kantong Kertas (Paperbag)"
                                    android:textColor="@color/color_text_dark"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ramah lingkungan &amp; biodegradable"
                                    android:textColor="@color/color_text_muted"
                                    android:textSize="10sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 2.000"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true" />

                        </RelativeLayout>

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="8dp" />

                        <!-- Option 1: Plastic bag -->
                        <RelativeLayout
                            android:id="@+id/btn_option_plastic"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingVertical="4dp">

                            <RadioButton
                                android:id="@+id/radio_plastic"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:clickable="false" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/radio_plastic"
                                android:layout_marginStart="6dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kantong Plastik Standard"
                                    android:textColor="@color/color_text_dark"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tahan air &amp; kuat"
                                    android:textColor="@color/color_text_muted"
                                    android:textSize="10sp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 1.000"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true" />

                        </RelativeLayout>

                        <!-- Courier plastic switch toggle -->
                        <LinearLayout
                            android:id="@+id/layout_plastic_switch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Kembalikan plastik ke kurir"
                                    android:textColor="@color/color_text_dark"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Dapatkan +10 Koin Hijau untuk kelestarian"
                                    android:textColor="@color/color_text_muted"
                                    android:textSize="10sp" />

                            </LinearLayout>

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switch_plastic_return"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Pricing Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/color_border_grey"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/color_surface_warm">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Rincian Pembayaran"
                            android:textColor="@color/color_text_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- Rows -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/text_subtotal_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Subtotal (0 Barang)"
                                android:textColor="@color/color_text_muted"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_subtotal_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 0"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/layout_discount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Diskon Belanja"
                                android:textColor="@color/color_text_muted"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_discount_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-Rp 5.000"
                                android:textColor="@color/color_red_error"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Biaya Kemasan"
                                android:textColor="@color/color_text_muted"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_packaging_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 2.000"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Biaya Pengiriman"
                                android:textColor="@color/color_text_muted"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gratis"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/color_border_grey"
                            android:layout_marginVertical="8dp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Pembayaran"
                                android:textColor="@color/color_text_dark"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/text_total_payment"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 0"
                                android:textColor="@color/color_accent_terracotta"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="30dp" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- Checkout Bottom Bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/color_surface_warm">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Yay, Pengiriman Gratis Ongkir Hari Ini! 🎉"
                    android:textColor="@color/color_primary_green"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_checkout_final"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Pesan Sekarang"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/color_primary_green"
                    app:cornerRadius="14dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Empty State Layout -->
    <LinearLayout
        android:id="@+id/layout_empty_cart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Top Header for Empty state too -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp">

            <ImageView
                android:id="@+id/btn_empty_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/color_text_dark"
                android:layout_alignParentStart="true"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_toEndOf="@id/btn_empty_back"
                android:layout_centerVertical="true"
                android:text="Keranjang"
                android:textColor="@color/color_text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/color_surface_warm">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/color_primary_green" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Keranjang belanja kosong"
            android:textColor="@color/color_text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="16dp"
            android:text="Kembali ke katalog untuk mengisi bahan makanan segar Anda."
            android:textColor="@color/color_text_muted"
            android:textSize="12sp"
            android:textAlignment="center" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_shopping"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Mulai Belanja"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/color_primary_green"
            app:cornerRadius="14dp" />

    </LinearLayout>

    <!-- Brown Undo Notification Card Overlay (Absolute bottom position) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_undo_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="100dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/color_accent_terracotta"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/text_undo_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menghapus Keju..."
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true" />

            <TextView
                android:id="@+id/btn_undo_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BATAL (UNDO)"
                android:textColor="@color/color_bg_warm"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:clickable="true"
                android:focusable="true" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
