<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_warm">

    <!-- Header bar -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/color_surface_warm"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/color_text_dark" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Right Buttons (Share & Favorite) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_share"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/color_surface_warm"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_share"
                    app:tint="@color/color_text_dark" />

            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="10dp"
                android:layout_height="match_parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_favorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/color_surface_warm"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/image_favorite"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/btn_star_big_off"
                    app:tint="@color/color_text_dark" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </RelativeLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Big Product Image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@color/color_surface_warm">

                <ImageView
                    android:id="@+id/image_product"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sapi" />

            </FrameLayout>

            <!-- Main Specs info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Tags / Rating Row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_alignParentStart="true">

                        <TextView
                            android:id="@+id/tag_discount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tag_terracotta"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="Diskon"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tag_primary"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="Baru"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_alignParentEnd="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/btn_star_big_on"
                            app:tint="@color/color_accent_terracotta" />

                        <TextView
                            android:id="@+id/text_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="4.9"
                            android:textColor="@color/color_text_dark"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </RelativeLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/text_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Nama Produk Pangan"
                    android:textColor="@color/color_text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:lineHeight="26sp" />

                <!-- Price row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:layout_alignParentStart="true">

                        <TextView
                            android:id="@+id/text_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 18.000"
                            android:textColor="@color/color_accent_terracotta"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_original_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Rp 24.000"
                            android:textColor="@color/color_text_muted"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/text_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" / 1 L"
                            android:textColor="@color/color_text_muted"
                            android:textSize="12sp"
                            android:layout_marginBottom="3dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_delivery_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_tag_olive"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="Kirim: Hari Ini"
                        android:textColor="@color/color_primary_green"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </RelativeLayout>

                <!-- Description/Ingredients -->
                <TextView
                    android:id="@+id/text_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Deskripsi kandungan bahan segar"
                    android:textColor="@color/color_text_muted"
                    android:textSize="13sp"
                    android:lineHeight="18sp" />

            </LinearLayout>

            <!-- TabLayout -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/color_bg_warm"
                app:tabTextColor="@color/color_text_muted"
                app:tabSelectedTextColor="@color/color_primary_green"
                app:tabIndicatorColor="@color/color_primary_green"
                app:tabIndicatorHeight="3dp"
                app:tabMode="fixed"
                app:tabGravity="fill">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ulasan" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resep" />

            </com.google.android.material.tabs.TabLayout>

            <!-- Sub content FrameLayout -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- 1. Detail Specs Tab layout -->
                <LinearLayout
                    android:id="@+id/layout_detail_spec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kandungan Nutrisi (per 100g):"
                        android:textColor="@color/color_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Nutrition grid row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Protein -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stepper_grey"
                            android:paddingVertical="8dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_nutr_protein"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3g"
                                android:textColor="@color/color_text_dark"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Protein"
                                android:textColor="@color/color_text_muted"
                                android:textSize="9sp" />

                        </LinearLayout>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="match_parent" />

                        <!-- Fat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stepper_grey"
                            android:paddingVertical="8dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_nutr_fat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5g"
                                android:textColor="@color/color_text_dark"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lemak"
                                android:textColor="@color/color_text_muted"
                                android:textSize="9sp" />

                        </LinearLayout>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="match_parent" />

                        <!-- Carbs -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stepper_grey"
                            android:paddingVertical="8dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_nutr_carbs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4.7g"
                                android:textColor="@color/color_text_dark"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Karbo"
                                android:textColor="@color/color_text_muted"
                                android:textSize="9sp" />

                        </LinearLayout>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="match_parent" />

                        <!-- Calories -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_stepper_grey"
                            android:paddingVertical="8dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_nutr_calories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="64 Kcal"
                                android:textColor="@color/color_text_dark"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Energi"
                                android:textColor="@color/color_text_muted"
                                android:textSize="9sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Spec rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Masa Simpan"
                                android:textColor="@color/color_text_muted"
                                android:textSize="12sp"
                                android:layout_alignParentStart="true" />

                            <TextView
                                android:id="@+id/text_spec_shelf_life"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5 Hari"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Penyimpanan"
                                android:textColor="@color/color_text_muted"
                                android:textSize="12sp"
                                android:layout_alignParentStart="true" />

                            <TextView
                                android:id="@+id/text_spec_storage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Suhu Dingin (+2°C s.d +6°C)"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kemasan"
                                android:textColor="@color/color_text_muted"
                                android:textSize="12sp"
                                android:layout_alignParentStart="true" />

                            <TextView
                                android:id="@+id/text_spec_packaging"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Botol Kaca steril 1 Liter"
                                android:textColor="@color/color_text_dark"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_alignParentEnd="true" />

                        </RelativeLayout>

                    </LinearLayout>

                    <!-- Tags wrap list (Diets, Allergens, Nutrients list) -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Karakteristik &amp; Nutrisi:"
                        android:textColor="@color/color_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Simple tag container using layout or horizontal scroll for ease -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:id="@+id/layout_characteristics_tags"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <!-- Populated dynamically in code -->
                        </LinearLayout>

                    </HorizontalScrollView>

                    <!-- Farmer mitra card -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Produsen Mitra Tani:"
                        android:textColor="@color/color_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Include farmer card -->
                    <include
                        android:id="@+id/layout_farmer_card"
                        layout="@layout/item_farmer_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="0dp"
                        android:layout_marginVertical="0dp" />

                    <!-- Certification card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/color_border_grey"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="@color/color_surface_warm">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_alignParentStart="true">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@android:drawable/checkbox_on_background"
                                    app:tint="@color/color_primary_green" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="Sertifikat Kualitas Produk"
                                    android:textColor="@color/color_text_dark"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                    android:layout_height="18dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@android:drawable/ic_media_next"
                                app:tint="@color/color_text_muted" />

                        </RelativeLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- 2. Reviews Tab layout -->
                <LinearLayout
                    android:id="@+id/layout_detail_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.9"
                            android:textColor="@color/color_text_dark"
                            android:textSize="32sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/color_accent_terracotta" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/color_accent_terracotta" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/color_accent_terracotta" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/color_accent_terracotta" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/color_accent_terracotta" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Berdasarkan 15 Ulasan Pembeli"
                                android:textColor="@color/color_text_muted"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_border_grey"
                        android:layout_marginBottom="16dp" />

                    <!-- Nested reviews items listing -->
                    <LinearLayout
                        android:id="@+id/layout_reviews_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <!-- Populated programmatically -->
                    </LinearLayout>

                </LinearLayout>

                <!-- 3. Recipes Tab layout -->
                <LinearLayout
                    android:id="@+id/layout_detail_recipes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Daftar Resep Berbahan Ini:"
                        android:textColor="@color/color_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_detail_recipes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar Panel (Add to cart action) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/color_surface_warm"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Harga:"
                    android:textColor="@color/color_text_muted"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/text_bottom_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 18.000"
                    android:textColor="@color/color_accent_terracotta"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Chat button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_chat_seller"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/color_primary_green"
                app:cardBackgroundColor="@color/color_surface_warm">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/stat_notify_chat"
                    app:tint="@color/color_primary_green" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Add to Cart or Stepper layout -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bottom_add"
                    android:layout_width="wrap_content"
                    android:layout_height="54dp"
                    android:text="Tambah ke Keranjang"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/color_primary_green"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_add" />

                <!-- Bottom Stepper component -->
                <LinearLayout
                    android:id="@+id/layout_bottom_stepper"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_stepper_green"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/btn_bottom_minus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/color_primary_green" />

                    <TextView
                        android:id="@+id/text_bottom_stepper_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="1 Pcs"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btn_bottom_plus"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_add"
                        app:tint="@color/color_primary_green" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
