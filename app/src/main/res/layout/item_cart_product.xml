<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/color_surface_warm"
    app:strokeColor="@color/color_border_grey"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Product Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/image_container"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/image_illustration"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/sapi" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Product Details -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Keju Kambing Organik"
            android:textColor="@color/color_text_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/image_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/text_item_total_price" />

        <TextView
            android:id="@+id/text_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Rp 45.000 / 200 g"
            android:textColor="@color/color_text_muted"
            android:textSize="11sp"
            app:layout_constraintStart_toEndOf="@id/image_container"
            app:layout_constraintTop_toBottomOf="@id/text_title"
            app:layout_constraintEnd_toStartOf="@id/text_item_total_price" />

        <!-- Stepper Component -->
        <LinearLayout
            android:id="@+id/layout_stepper"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_stepper_grey"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            app:layout_constraintStart_toEndOf="@id/image_container"
            app:layout_constraintTop_toBottomOf="@id/text_subtitle">

            <ImageView
                android:id="@+id/btn_stepper_minus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_circle_white"
                android:padding="5dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/color_text_dark" />

            <TextView
                android:id="@+id/text_stepper_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="1 pcs"
                android:textColor="@color/color_text_dark"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_stepper_plus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_circle_white"
                android:padding="5dp"
                android:src="@android:drawable/ic_menu_add"
                app:tint="@color/color_text_dark" />

        </LinearLayout>

        <!-- Item Total Price -->
        <TextView
            android:id="@+id/text_item_total_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 45.000"
            android:textColor="@color/color_accent_terracotta"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
